# Variabili di ambiente per il server

# Porta del server
PORT=3000

# Secret per JWT (CAMBIA QUESTO IN PRODUZIONE!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Chiave di crittografia per le foto (32 byte in hex)
# Genera una nuova chiave con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
