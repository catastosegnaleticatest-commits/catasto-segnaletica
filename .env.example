# Copia questo file in .env e compila i valori

# URL del server cloud (dopo il deploy su Fly.io sarà https://catasto-segnaletica.fly.dev)
VITE_API_URL=https://catasto-segnaletica.fly.dev

# Secrets server (impostati su Fly.io con: fly secrets set ...)
JWT_SECRET=cambia-questo-con-una-stringa-casuale-lunga
ENCRYPTION_KEY=cambia-questo-con-32-byte-hex-casuali
ADMIN_PASSWORD=password-admin-iniziale
